# ─── Google ───────────────────────────────────────────────────────────────
GOOGLE_MAPS_API_KEY=
GOOGLE_SHEETS_ID=
GOOGLE_SERVICE_ACCOUNT_JSON=./creds.json

# ─── LLM ─────────────────────────────────────────────────────────────────
# Provider auto-detects: if only ANTHROPIC_API_KEY is set → anthropic.
# If only OPENAI_API_KEY is set → openai. Leave LLM_PROVIDER blank unless
# both keys are set and you need to force one.
LLM_PROVIDER=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Model names auto-default per provider. Override only if you want to:
#   anthropic → claude-haiku-4-5 / claude-opus-4-7
#   openai    → gpt-4o-mini      / gpt-4-turbo
CHEAP_MODEL=
PREMIUM_MODEL=

# ─── Pipeline behaviour ──────────────────────────────────────────────────
MAX_RUN_COST_USD=5.00
MAX_CONCURRENT_SITES=5
REQUEST_DELAY_SECONDS=1
RESCAN_COOLDOWN_DAYS=30
LIMIT_PER_PAIR=25

# ─── Qualification thresholds (keep unless you know what you're doing) ──
MIN_CRITICAL=1
MIN_SERIOUS=3
MIN_TOTAL_VIOLATIONS=15
MIN_LEAD_SCORE=60

# ─── Business identity (CAN-SPAM compliance) ─────────────────────────────
MY_BUSINESS_NAME=BizStreamPro
MY_BUSINESS_ADDRESS=
MY_SENDER_NAME=
MY_SENDER_EMAIL=
MY_UNSUBSCRIBE_URL=
MY_CALENDAR_LINK=
MY_WEBSITE=
